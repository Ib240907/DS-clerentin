C#
public class Boutique
{
    public List<string> Inventaire { get; set; }

    public Boutique()
    {
        Inventaire = new List<string>(); // Toujours initialiser !
    }

    public void Ajouter(string produit)
    {
        Inventaire.Add(produit);
    }

    public bool EstDisponible(string produit)
    {
        return Inventaire.Contains(produit); // Renvoie Vrai ou Faux
    }
}
SITUATION 6 : L'Aléatoire (Random)
Sujet : "Tirer au sort", "Choisir un mot au hasard"...

C#
public string TirageAuSort()
{
    string[] mots = { "Pomme", "Poire", "Banane" };
    Random hasard = new Random();
   
    int index = hasard.Next(0, mots.Length);
    return mots[index];
}
